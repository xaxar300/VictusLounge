<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="VictusLounge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:VictusLounge.Helpers"
        xmlns:views="clr-namespace:VictusLounge.Views"
        Title="VictusLounge Control Center"
        Width="1480"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBackgroundBrush}"
        helpers:EventCommandBinder.PreviewKeyDownCommand="{Binding Shell.PreviewKeyDownCommand}">
    <Grid x:Name="RootGrid"
          Background="{DynamicResource WindowBackgroundBrush}"
          helpers:EventCommandBinder.PreviewMouseDownCommand="{Binding Shell.PreviewMouseDownCommand}">
        <Border x:Name="ShellRoot" Background="{DynamicResource ShellBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="264" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Background="{DynamicResource TitlebarBrush}"
                        BorderBrush="{DynamicResource LineSoftBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                            <TextBlock Text="VictusLounge Control Center"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=" / " Foreground="{DynamicResource DimBrush}" FontSize="13" Margin="8,0" />
                            <TextBlock x:Name="CurrentViewText"
                                       Text="{Binding Navigation.CurrentTitle}"
                                       Foreground="{DynamicResource GoldLightBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="390"
                                Height="34"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                CornerRadius="11"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="12,0"
                                Margin="0,0,14,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                                <TextBox x:Name="GlobalSearchBox"
                                         Text="{Binding Shell.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         Foreground="{DynamicResource TextBrush}"
                                         ToolTip="Поиск: клиент, PC-04, бронь, турнир, платеж..." />
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock x:Name="TopLanguageLabel" Text="Language" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Border CornerRadius="13" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="5">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TopRuButton" Content="RU" Style="{StaticResource PrimaryButtonStyle}" MinHeight="28" Padding="12,0" Tag="ru" Command="{Binding Settings.LanguageCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                    <Button x:Name="TopEnButton" Content="EN" Style="{StaticResource GhostButtonStyle}" MinHeight="28" Padding="12,0" Tag="en" Command="{Binding Settings.LanguageCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="3"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="10,5"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                            <TextBlock x:Name="WorkspaceText" Text="{Binding Navigation.WorkspaceTitle}" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                        </Border>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="NotificationButton"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Width="42"
                                    MinHeight="34"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    Command="{Binding Notifications.ToggleCommand}">
                                <Grid>
                                    <TextBlock Text="&#xE7F4;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border x:Name="NotificationBadge" CornerRadius="7" Background="{DynamicResource DangerBrush}" Padding="4,0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-5,0" Visibility="Collapsed">
                                        <TextBlock x:Name="NotificationCountText" Text="0" FontSize="10" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="Sidebar"
                        Grid.Row="1"
                        Grid.Column="0"
                        BorderBrush="{DynamicResource LineSoftBrush}"
                        BorderThickness="0,0,1,0"
                        Background="{DynamicResource ShellBackgroundBrush}"
                        Padding="19">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="46" Height="46" CornerRadius="14" Background="{DynamicResource GoldButtonBrush}">
                                <TextBlock Text="VL" Foreground="#111111" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel x:Name="BrandTextPanel" Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock x:Name="BrandTitle" Text="VictusLounge" FontWeight="Bold" />
                                <TextBlock x:Name="BrandSubtitle" Text="Gaming lounge workspace" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    x:Name="SidebarToggle"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Width="34"
                                    MinHeight="34"
                                    Padding="0"
                                    Command="{Binding Navigation.ToggleSidebarCommand}">
                                <Path x:Name="SidebarToggleIcon"
                                      Data="M 9 5 L 5 9 L 9 13"
                                      Stroke="{DynamicResource GoldLightBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Width="14"
                                      Height="18"
                                      Stretch="Uniform" />
                            </Button>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Margin="0,18,0,18" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Button x:Name="DashboardNavButton" Tag="dashboard" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenDashboard, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsDashboardActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Главная" /></StackPanel>
                                </Button>
                                <Button x:Name="MapNavButton" Margin="0,7,0,0" Tag="map" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenMap, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsMapActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE707;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Схема клуба" /></StackPanel>
                                </Button>
                                <Button x:Name="BookingNavButton" Margin="0,7,0,0" Tag="booking" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenBooking, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsBookingActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Бронирование" /></StackPanel>
                                </Button>
                                <Button x:Name="CabinetNavButton" Margin="0,7,0,0" Tag="cabinet" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenCabinet, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsCabinetActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Кабинет" /></StackPanel>
                                </Button>
                                <Button x:Name="BalanceNavButton" Margin="0,7,0,0" Tag="balance" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenBalance, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsBalanceActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Баланс" /></StackPanel>
                                </Button>
                                <Button x:Name="EventsNavButton" Margin="0,7,0,0" Tag="events" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenEvents, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsEventsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xEC92;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="События" /></StackPanel>
                                </Button>
                                <Button x:Name="AdminNavButton" Margin="0,7,0,0" Tag="admin" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenAdmin, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsAdminActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7EF;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Админ" /></StackPanel>
                                </Button>
                                <Button x:Name="ShiftNavButton" Margin="0,7,0,0" Tag="shift" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenShift, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsShiftActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE823;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Смена" /></StackPanel>
                                </Button>
                                <Button x:Name="OwnerNavButton" Margin="0,7,0,0" Tag="owner" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="{Binding Navigation.CanOpenOwner, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsOwnerActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE7FD;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Владелец" /></StackPanel>
                                </Button>
                                <Button x:Name="SettingsNavButton" Margin="0,7,0,0" Tag="settings" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Navigation.IsSettingsActive}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                                    <Setter Property="Background" Value="#2BD4AF37" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                                                    <Setter Property="BorderThickness" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Настройки" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <Border x:Name="SidebarProfileCard" Grid.Row="2" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#14D4AF37" Padding="13">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="46" Height="46" CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}">
                                    <TextBlock x:Name="ProfileInitialsText" Text="{Binding CurrentUser.Initials}" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel x:Name="ProfileText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ProfileNameText" Text="{Binding CurrentUser.FullName}" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="ProfileRoleText" Text="{Binding CurrentUser.RoleAndLogin}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,14,0,0">
                            <TextBlock x:Name="LogoutText" Text="Выйти" Foreground="{DynamicResource MutedBrush}" FontSize="12" HorizontalAlignment="Left" Cursor="Hand">
                                <TextBlock.InputBindings>
                                    <MouseBinding MouseAction="LeftClick" Command="{Binding Navigation.LogoutCommand}" />
                                </TextBlock.InputBindings>
                            </TextBlock>
                            <TextBlock x:Name="SidebarVersionText" Text="v1.0" Foreground="{DynamicResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource WindowBackgroundBrush}">
                    <StackPanel Margin="18">
                        <Border x:Name="AnnouncementBar"
                                Height="40"
                                CornerRadius="13"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                Background="#1CD4AF37"
                                ClipToBounds="True"
                                Margin="0,0,0,18">
                            <Canvas x:Name="AnnouncementCanvas" Margin="18,0">
                                <TextBlock x:Name="AnnouncementTextA"
                                           Text="Данные клуба загружаются из SQL Server · тарифы, брони и статусы ПК обновятся после подключения ·"
                                           Foreground="{DynamicResource GoldLightBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Canvas.Top="11" />
                                <TextBlock x:Name="AnnouncementTextB"
                                           Text="{Binding Text, ElementName=AnnouncementTextA}"
                                           Foreground="{DynamicResource GoldLightBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Canvas.Top="11" />
                            </Canvas>
                        </Border>

                        <views:DashboardViewControl x:Name="DashboardView" />

                        <views:ClubMapView x:Name="MapView" Visibility="Collapsed" />

                        <views:BookingView x:Name="BookingView" Visibility="Collapsed" />

                        <views:ClientCabinetView x:Name="CabinetView" Visibility="Collapsed" />

                        <views:BalanceView x:Name="BalanceView" Visibility="Collapsed" />

                        <views:EventsView x:Name="EventsView" Visibility="Collapsed" />

                        <views:AdminDashboardView x:Name="AdminView" Visibility="Collapsed" />

                        <views:ShiftView x:Name="ShiftView" Visibility="Collapsed" />

                        <views:OwnerDashboardView x:Name="OwnerView" Visibility="Collapsed" />
                        <views:SettingsView x:Name="SettingsView" Visibility="Collapsed" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <views:AuthOverlayView x:Name="AuthOverlay" Visibility="{Binding Navigation.IsAuthOverlayVisible, Converter={StaticResource BoolToVisibilityConverter}}" />

        <views:TopupOverlayView x:Name="TopupOverlay" Visibility="Collapsed" />
        <views:NotificationCenterView x:Name="NotificationCenter" Visibility="Collapsed" />

        <views:StatusToastView x:Name="StatusToast" Visibility="Collapsed" />

        <Border x:Name="UndoSnackbar"
                Width="430"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                CornerRadius="14"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelGradientBrush}"
                Padding="14"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="UndoSnackbarTitleText"
                               Text="Действие выполнено"
                               Foreground="{DynamicResource GoldLightBrush}"
                               FontWeight="Black"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="UndoSnackbarBodyText"
                               Text="Можно отменить последнее действие."
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,5,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
                <Button x:Name="UndoSnackbarButton"
                        Grid.Column="1"
                        Content="Отменить"
                        Style="{StaticResource GhostButtonStyle}"
                        MinHeight="34"
                        Padding="14,0"
                        Margin="14,0,0,0" />
            </Grid>
        </Border>

        <views:BookingConfirmOverlayView x:Name="BookingConfirmOverlay" Visibility="Collapsed" />
    </Grid>
</Window>
