<UserControl x:Class="VictusLounge.Views.DashboardViewControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<StackPanel>
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="24" Margin="0,0,0,16">
                            <Border.Background>
                                <ImageBrush ImageSource="pack://application:,,,/Assets/Dashboard.png" Stretch="UniformToFill" Opacity="0.34" />
                            </Border.Background>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.5*" />
                                </Grid.ColumnDefinitions>
                                <Rectangle Grid.RowSpan="2" Grid.ColumnSpan="2" Fill="#CC111111" RadiusX="12" RadiusY="12" />

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="CLUB STATUS" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Рабочая панель клуба" FontSize="38" FontWeight="Black" Margin="0,7,0,8" TextWrapping="Wrap" />
                                    <TextBlock Text="Состояние зала, броней и смены на сегодня." Style="{StaticResource MutedTextStyle}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="Новая бронь" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,11,0" Tag="booking" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                        <Button Content="Схема" Style="{StaticResource GhostButtonStyle}" Margin="0,0,11,0" Tag="map" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                        <Button Content="События" Style="{StaticResource GhostButtonStyle}" Tag="events" Command="{Binding Dashboard.QuickActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                    </StackPanel>
                                </StackPanel>

                                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="4" Margin="20,0,0,0">
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#13D4AF37" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="DashboardFreePcsLabel" Text="Свободно ПК" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock x:Name="DashboardFreePcsValue" Text="0" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock x:Name="DashboardFreePcsHint" Text="из 0" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="DashboardZonesLabel" Text="Доступные зоны" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock x:Name="DashboardZonesValue" Text="0/0" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock x:Name="DashboardZonesHint" Text="есть свободные места" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="DashboardBookingLabel" Text="Мои брони" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock x:Name="DashboardBookingValue" Text="0" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock x:Name="DashboardBookingHint" Text="нет ближайшей брони" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="DashboardEventsLabel" Text="События сегодня" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock x:Name="DashboardEventsValue" Text="3" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock x:Name="DashboardEventsHint" Text="Dota 2 · CS2 · LAN" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="4" Margin="0,20,0,0">
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Standard" FontWeight="Bold" />
                                            <ProgressBar x:Name="StandardZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                            <TextBlock x:Name="StandardZoneLoadText" Text="0/0 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,7,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="VIP" FontWeight="Bold" />
                                            <ProgressBar x:Name="VipZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                            <TextBlock x:Name="VipZoneLoadText" Text="0/0 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,7,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Bootcamp" FontWeight="Bold" />
                                            <ProgressBar x:Name="BootcampZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                            <TextBlock x:Name="BootcampZoneLoadText" Text="0/0 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,7,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Royal" FontWeight="Bold" />
                                            <ProgressBar x:Name="RoyalZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                            <TextBlock x:Name="RoyalZoneLoadText" Text="0/0 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,7,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.ColumnSpan="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,16">
                                <StackPanel>
                                    <TextBlock Text="QUICK ACTIONS" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Быстрые действия" FontSize="22" FontWeight="Bold" Margin="0,6,0,16" />
                                    <UniformGrid Columns="4">
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="142" Background="#18D4AF37" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="booking" Command="{Binding Dashboard.QuickActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource GoldButtonBrush}" HorizontalAlignment="Left">
                                                    <TextBlock Text="&#xE787;" FontFamily="Segoe MDL2 Assets" Foreground="#111111" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Новая бронь" FontWeight="Black" TextWrapping="Wrap" />
                                                    <TextBlock Text="Timeline, зона, ПК" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="2" Text="Открыть форму" Foreground="{DynamicResource GoldLightBrush}" FontSize="12" FontWeight="Bold" />
                                            </Grid>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="142" Background="#142F6F48" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="tournament" Command="{Binding Dashboard.QuickActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10" Background="#2268D889" BorderBrush="{DynamicResource OkBrush}" BorderThickness="1" HorizontalAlignment="Left">
                                                    <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource OkBrush}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Турнир" FontWeight="Black" TextWrapping="Wrap" />
                                                    <TextBlock Text="Dota 2, CS2, LAN" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="2" Text="3 события" Foreground="{DynamicResource OkBrush}" FontSize="12" FontWeight="Bold" />
                                            </Grid>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="142" Background="#18EDC86B" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="package" Command="{Binding Dashboard.QuickActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10" Background="#22EDC86B" BorderBrush="{DynamicResource WaitBrush}" BorderThickness="1" HorizontalAlignment="Left">
                                                    <TextBlock Text="&#xE8C7;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource WaitBrush}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Пакеты" FontWeight="Black" TextWrapping="Wrap" />
                                                    <TextBlock Text="Quick Game / Night" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="2" Text="Пополнить баланс" Foreground="{DynamicResource WaitBrush}" FontSize="12" FontWeight="Bold" />
                                            </Grid>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="142" Background="#12FFFFFF" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Tag="profile" Command="{Binding Dashboard.QuickActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}">
                                            <Grid>
                                                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                                <Border Width="36" Height="36" CornerRadius="10" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" HorizontalAlignment="Left">
                                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" Foreground="{DynamicResource GoldLightBrush}" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                                                    <TextBlock Text="Профиль" FontWeight="Black" TextWrapping="Wrap" />
                                                    <TextBlock Text="Бонусы и брони" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                                </StackPanel>
                                                <TextBlock Grid.Row="2" Text="Client workspace" Foreground="{DynamicResource GoldLightBrush}" FontSize="12" FontWeight="Bold" />
                                            </Grid>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                                <StackPanel x:Name="TodayClubList">
                                    <TextBlock Text="Сегодня в клубе" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                                    <TextBlock Text="Данные загружаются из бронирований и сессий." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Button Content="Схема" DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" MinHeight="34" Padding="14,0" Tag="map" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                        <StackPanel>
                                            <TextBlock Text="ZONES" Style="{StaticResource KickerTextStyle}" />
                                            <TextBlock Text="Зоны клуба" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                    <UniformGrid Columns="4">
                                        <Border CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Height="178" Margin="0,0,10,0" Cursor="Hand" Tag="Standard" ClipToBounds="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/Assets/Standard.png" Stretch="UniformToFill" Opacity="0.46" />
                                            </Border.Background>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding Dashboard.SelectZoneCommand}" CommandParameter="Standard" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Rectangle Fill="#B0101010" RadiusX="14" RadiusY="14" />
                                                <Grid Margin="16">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="44" />
                                                        <RowDefinition Height="56" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" CornerRadius="9" Background="#22D4AF37" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="8,4">
                                                            <TextBlock Text="18 free" Foreground="{DynamicResource GoldLightBrush}" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="Standard" FontSize="16" FontWeight="Bold" />
                                                            <TextBlock Text="Main hall" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1" Text="28 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="34" FontWeight="Black" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Row="2" Text="8 BYN/час · высокая доступность" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Height="178" Margin="0,0,10,0" Cursor="Hand" Tag="VIP" ClipToBounds="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/Assets/VIP.png" Stretch="UniformToFill" Opacity="0.44" />
                                            </Border.Background>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding Dashboard.SelectZoneCommand}" CommandParameter="VIP" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Rectangle Fill="#B0121010" RadiusX="14" RadiusY="14" />
                                                <Grid Margin="16">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="44" />
                                                        <RowDefinition Height="56" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" CornerRadius="9" Background="#22EDC86B" BorderBrush="{DynamicResource WaitBrush}" BorderThickness="1" Padding="8,4">
                                                            <TextBlock Text="4 free" Foreground="{DynamicResource WaitBrush}" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="VIP" FontSize="16" FontWeight="Bold" />
                                                            <TextBlock Text="Quiet seats" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1" Text="10 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="34" FontWeight="Black" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Row="2" Text="14 BYN/час · 4 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Height="178" Margin="0,0,10,0" Cursor="Hand" Tag="Bootcamp" ClipToBounds="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/Assets/Bootcamp.png" Stretch="UniformToFill" Opacity="0.46" />
                                            </Border.Background>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding Dashboard.SelectZoneCommand}" CommandParameter="Bootcamp" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Rectangle Fill="#B00C1510" RadiusX="14" RadiusY="14" />
                                                <Grid Margin="16">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="44" />
                                                        <RowDefinition Height="56" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" CornerRadius="9" Background="#2268D889" BorderBrush="{DynamicResource OkBrush}" BorderThickness="1" Padding="8,4">
                                                            <TextBlock Text="1 room" Foreground="{DynamicResource OkBrush}" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="Bootcamp" FontSize="16" FontWeight="Bold" />
                                                            <TextBlock Text="Team room" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1" Text="2 комнаты" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Grid.Row="2" Text="50 BYN/час · 1 свободна" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                        <Border CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Height="178" Cursor="Hand" Tag="Royal VIP" ClipToBounds="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="pack://application:,,,/Assets/RoyalVip.png" Stretch="UniformToFill" Opacity="0.46" />
                                            </Border.Background>
                                            <Border.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding Dashboard.SelectZoneCommand}" CommandParameter="Royal VIP" />
                                            </Border.InputBindings>
                                            <Grid>
                                                <Rectangle Fill="#B0101010" RadiusX="14" RadiusY="14" />
                                                <Grid Margin="16">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="44" />
                                                        <RowDefinition Height="56" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <DockPanel>
                                                        <Border DockPanel.Dock="Right" CornerRadius="9" Background="#22FFFFFF" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Padding="8,4">
                                                            <TextBlock Text="3 free" Foreground="{DynamicResource GoldLightBrush}" FontSize="11" FontWeight="Bold" />
                                                        </Border>
                                                        <StackPanel>
                                                            <TextBlock Text="Royal VIP" FontSize="16" FontWeight="Bold" />
                                                            <TextBlock Text="Premium" Foreground="{DynamicResource MutedBrush}" FontSize="11" Margin="0,3,0,0" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                    <TextBlock Grid.Row="1" Text="4 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="34" FontWeight="Black" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Row="2" Text="24 BYN/час · 3 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Последние уведомления" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,13"><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Ellipse Width="10" Height="10" Fill="{DynamicResource OkBrush}" VerticalAlignment="Top" Margin="0,5,0,0" /><StackPanel Grid.Column="1"><TextBlock Text="PC-07 свободен" FontWeight="Bold" /><TextBlock Text="Standard Hall" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" /></StackPanel></Grid>
                                    <Grid Margin="0,0,0,13"><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Ellipse Width="10" Height="10" Fill="{DynamicResource WaitBrush}" VerticalAlignment="Top" Margin="0,5,0,0" /><StackPanel Grid.Column="1"><TextBlock Text="Бронь скоро начнется" FontWeight="Bold" TextWrapping="Wrap" /><TextBlock Text="VIP-03 · 18:00" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" /></StackPanel></Grid>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Ellipse Width="10" Height="10" Fill="{DynamicResource DangerBrush}" VerticalAlignment="Top" Margin="0,5,0,0" /><StackPanel Grid.Column="1"><TextBlock Text="PC-18 service" FontWeight="Bold" /><TextBlock Text="Требуется проверка" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" /></StackPanel></Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                        </StackPanel>
</UserControl>
