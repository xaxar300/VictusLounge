<UserControl x:Class="VictusLounge.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <DockPanel Margin="0,0,0,18" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="ADMIN CONTROL" Style="{StaticResource KickerTextStyle}" />
                <TextBlock Text="Админ-панель" FontSize="32" FontWeight="Black" Margin="0,7,0,8" />
                <TextBlock Text="Очередь задач, текущие сессии и операции смены в одном рабочем экране." Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
            <Button Content="Новая сессия"
                    DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Tag="admin-new-session"
                    Command="{Binding Admin.ActionCommand}"
                    CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"
                    Width="180"
                    VerticalAlignment="Top" />
        </DockPanel>

        <UniformGrid Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Активные сессии" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminActiveSessionsValue" Text="0" Foreground="{DynamicResource GoldLightBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock Text="открытые в БД" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Ожидают оплату" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminPaymentQueueValue" Text="0" Foreground="{DynamicResource StatusReservedBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock x:Name="AdminPaymentQueueHintText" Text="0 броней, 0 сессий" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Свободные ПК" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminFreePcsValue" Text="0" Foreground="{DynamicResource StatusFreeBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock x:Name="AdminFreePcsHintText" Text="из 0 рабочих мест" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Техподдержка" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminSupportValue" Text="0" Foreground="{DynamicResource StatusServiceBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock Text="ПК в сервисе и задачи зала" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <Button Content="Карта"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButtonStyle}"
                                MinHeight="34"
                                Padding="14,0"
                                Tag="map"
                                Command="{Binding Navigation.NavigateCommand}"
                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                        <StackPanel>
                            <TextBlock Text="LIVE SESSIONS" Style="{StaticResource KickerTextStyle}" />
                            <TextBlock Text="Текущие сессии" FontSize="24" FontWeight="Black" Margin="0,6,0,0" />
                        </StackPanel>
                    </DockPanel>
                    <Grid x:Name="AdminSessionsGrid">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.75*" />
                            <ColumnDefinition Width="1.25*" />
                            <ColumnDefinition Width="0.8*" />
                            <ColumnDefinition Width="0.95*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="ПК" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Клиент" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="До" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Статус" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="4" Text="Действие" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TASK QUEUE" Style="{StaticResource KickerTextStyle}" />
                        <TextBlock Text="Очередь задач" FontSize="24" FontWeight="Black" Margin="0,6,0,12" />
                        <StackPanel x:Name="AdminTaskQueueList">
                            <TextBlock Text="Задачи появятся после загрузки данных." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                    <StackPanel x:Name="AdminQuickOpsPanel">
                        <TextBlock Text="Быстрые операции" FontSize="22" FontWeight="Black" Margin="0,0,0,14" />
                        <UniformGrid Columns="2">
                            <Button Content="Оплата" Style="{StaticResource PrimaryButtonStyle}" Tag="admin-payment" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,8,8" />
                            <Button Content="Бронь" Style="{StaticResource GhostButtonStyle}" Tag="booking" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,0,8" />
                            <Button Content="Перенести" Style="{StaticResource GhostButtonStyle}" Tag="admin-reschedule-booking" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,8,8" />
                            <Button Content="Отменить" Style="{StaticResource GhostButtonStyle}" Tag="admin-cancel-booking" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,0,8" />
                            <Button Content="В сервис" Style="{StaticResource GhostButtonStyle}" Tag="admin-service" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,8,8" />
                            <Button Content="Снять сервис" Style="{StaticResource GhostButtonStyle}" Tag="admin-clear-service" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,0,8" />
                            <Button Content="Закрыть оплаты" Style="{StaticResource GhostButtonStyle}" Tag="admin-settle-all" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" Margin="0,0,8,0" />
                            <Button Content="Карта" Style="{StaticResource GhostButtonStyle}" Tag="map" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="38" Padding="12,0" />
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Журнал операций" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" Margin="0,0,0,8" />
                        <StackPanel x:Name="AdminOperationLogList">
                            <TextBlock Text="Журнал операций пуст" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
