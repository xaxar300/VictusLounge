<UserControl x:Class="VictusLounge.Views.AdminDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:VictusLounge.Helpers"
             xmlns:vm="clr-namespace:VictusLounge.ViewModels"
             Background="Transparent">
    <StackPanel>
        <DockPanel Margin="0,0,0,18" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="ADMIN CONTROL" Style="{StaticResource KickerTextStyle}" />
                <TextBlock Text="Админ-панель" FontSize="32" FontWeight="Black" Margin="0,7,0,8" />
                <TextBlock Text="Очередь задач, текущие сессии и операции смены в одном рабочем экране." Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
            <Button Content="Новая сессия"
                    DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Tag="admin-new-session"
                    Command="{Binding Admin.ActionCommand}"
                    CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"
                    Width="180"
                    VerticalAlignment="Top" />
        </DockPanel>

        <UniformGrid Columns="4" Margin="0,0,0,16">
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Активные сессии" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminActiveSessionsValue" Text="0" Foreground="{DynamicResource GoldLightBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock Text="открытые в БД" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Ожидают оплату" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminPaymentQueueValue" Text="0" Foreground="{DynamicResource StatusReservedBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock x:Name="AdminPaymentQueueHintText" Text="0 броней, 0 сессий" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Свободные ПК" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminFreePcsValue" Text="0" Foreground="{DynamicResource StatusFreeBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock x:Name="AdminFreePcsHintText" Text="из 0 рабочих мест" Foreground="{DynamicResource MutedBrush}" />
                </StackPanel>
            </Border>
            <Border Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="Техподдержка" Foreground="{DynamicResource MutedBrush}" />
                    <TextBlock x:Name="AdminSupportValue" Text="0" Foreground="{DynamicResource StatusServiceBrush}" FontSize="34" FontWeight="Black" Margin="0,8,0,0" />
                    <TextBlock Text="ПК в сервисе и задачи зала" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.35*" />
                <ColumnDefinition Width="0.85*" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16">
                        <Button Content="Карта"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButtonStyle}"
                                MinHeight="34"
                                Padding="14,0"
                                Tag="map"
                                Command="{Binding Navigation.NavigateCommand}"
                                CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                        <StackPanel>
                            <TextBlock Text="LIVE SESSIONS" Style="{StaticResource KickerTextStyle}" />
                            <TextBlock Text="Текущие сессии" FontSize="24" FontWeight="Black" Margin="0,6,0,0" />
                        </StackPanel>
                    </DockPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions><Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="ПК" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="1" Text="Клиент" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="2" Text="До" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                        <TextBlock Grid.Column="3" Text="Статус" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="Действие" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Center" />
                    </Grid>
                    <ItemsControl x:Name="AdminSessionsGrid" ItemsSource="{Binding Admin.Sessions}" Margin="0,4,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="48" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions><TextBlock Text="{Binding ComputerName}" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="{Binding ClientName}" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding EndText}" TextWrapping="Wrap" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    <Border Grid.Column="3" Style="{StaticResource StatusBadgeStyle}" Margin="0" MinWidth="118" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="SessionStatusText" Text="{Binding StatusText}" Style="{StaticResource StatusBadgeTextStyle}" />
                                    </Border>
                                    <Button Grid.Column="4"
                                            Content="{Binding ActionText}"
                                            Command="{Binding DataContext.Admin.ActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding ActionCommandParameter}"
                                            MinHeight="34"
                                            MinWidth="136"
                                            Padding="14,0"
                                            Margin="0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding HasAction, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPrimaryAction}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource GoldButtonBrush}" />
                                                        <Setter Property="Foreground" Value="#111111" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static helpers:SessionStatus.AwaitingPayment}">
                                        <Setter TargetName="SessionStatusText" Property="Foreground" Value="{DynamicResource StatusReservedBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static helpers:SessionStatus.Active}">
                                        <Setter TargetName="SessionStatusText" Property="Foreground" Value="{DynamicResource StatusFreeBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="{x:Static helpers:SessionStatus.Team}">
                                        <Setter TargetName="SessionStatusText" Property="Foreground" Value="{DynamicResource GoldLightBrush}" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1">
                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="TASK QUEUE" Style="{StaticResource KickerTextStyle}" />
                        <TextBlock Text="Очередь задач" FontSize="24" FontWeight="Black" Margin="0,6,0,12" />
                        <ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AdminTaskQueueList" ItemsSource="{Binding Admin.TaskQueue}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10"
                                            BorderBrush="{DynamicResource LineSoftBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource SurfaceBrush}"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock x:Name="TaskTitleText" Text="{Binding Title}" FontWeight="Black" TextWrapping="Wrap" />
                                                <TextBlock Text="{Binding Details}" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{Binding ActionText}"
                                                    Command="{Binding DataContext.Admin.ActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding ActionCommandParameter}"
                                                    MinHeight="32"
                                                    Padding="12,0"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasAction, Converter={StaticResource BoolToVisibilityConverter}}">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPrimaryAction}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource GoldButtonBrush}" />
                                                                <Setter Property="Foreground" Value="#111111" />
                                                                <Setter Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:AdminTaskKind.Payment}">
                                            <Setter TargetName="TaskTitleText" Property="Foreground" Value="{DynamicResource StatusReservedBrush}" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:AdminTaskKind.Service}">
                                            <Setter TargetName="TaskTitleText" Property="Foreground" Value="{DynamicResource StatusServiceBrush}" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                    <StackPanel x:Name="AdminQuickOpsPanel">
                        <TextBlock Text="Быстрые операции" FontSize="22" FontWeight="Black" Margin="0,0,0,14" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="56" />
                                <RowDefinition Height="56" />
                                <RowDefinition Height="56" />
                            </Grid.RowDefinitions>
                            <Button Grid.Row="0" Grid.Column="0" Content="Оплата" Style="{StaticResource PrimaryButtonStyle}" Tag="admin-payment" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="0,0,8,8" />
                            <Button Grid.Row="0" Grid.Column="1" Content="Перенести" Style="{StaticResource GhostButtonStyle}" Tag="admin-reschedule-booking" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="8,0,0,8" />
                            <Button Grid.Row="1" Grid.Column="0" Content="Отменить" Style="{StaticResource GhostButtonStyle}" Tag="admin-cancel-booking" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="0,4,8,4" />
                            <Button Grid.Row="1" Grid.Column="1" Content="В сервис" Style="{StaticResource GhostButtonStyle}" Tag="admin-service" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="8,4,0,4" />
                            <Button Grid.Row="2" Grid.Column="0" Content="Снять сервис" Style="{StaticResource GhostButtonStyle}" Tag="admin-clear-service" Command="{Binding Admin.ActionCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="0,8,8,0" />
                            <Button Grid.Row="2" Grid.Column="1" Content="Карта" Style="{StaticResource GhostButtonStyle}" Tag="map" Command="{Binding Navigation.NavigateCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="44" Margin="8,8,0,0" />
                        </Grid></StackPanel>
                </Border>

                <Border Style="{StaticResource PanelBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="Журнал операций" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" Margin="0,0,0,8" />
                        <StackPanel x:Name="AdminOperationLogList">
                            <TextBlock Text="Журнал операций пуст" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </StackPanel>
</UserControl>
