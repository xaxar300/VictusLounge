<UserControl x:Class="VictusLounge.Views.NotificationCenterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<Border
                Width="390"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,58,58,0"
                CornerRadius="16"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelGradientBrush}"
                Padding="16">
            <StackPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="NOTIFICATION CENTER" Style="{StaticResource KickerTextStyle}" />
                        <TextBlock Text="Уведомления" FontSize="24" FontWeight="Black" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button x:Name="MarkNotificationsButton"
                            Content="Прочитать"
                            DockPanel.Dock="Right"
                            Style="{StaticResource GhostButtonStyle}"
                            MinHeight="34"
                            Padding="14,0"
                            Click="MarkNotifications_Click" />
                </DockPanel>

                <StackPanel x:Name="NotificationList" />

                <TextBlock x:Name="NotificationEmptyText"
                           Text="Новых уведомлений нет."
                           Foreground="{DynamicResource MutedBrush}"
                           TextAlignment="Center"
                           Padding="16"
                           Visibility="Visible" />
            </StackPanel>
        </Border>
</UserControl>
