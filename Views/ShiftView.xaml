<UserControl x:Class="VictusLounge.Views.ShiftView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<StackPanel>
                            <DockPanel Margin="0,0,0,18" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="SHIFT DESK" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Смена и касса" FontSize="38" FontWeight="Black" Margin="0,7,0,8" />
                                    <TextBlock Text="Контроль смены, кассовых операций, задач и инцидентов." Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <Button Content="Закрыть смену" DockPanel.Dock="Right" Style="{StaticResource PrimaryButtonStyle}" Tag="shift-close" Click="AdminAction_Click" Width="170" VerticalAlignment="Top" />
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="0.9*" /><ColumnDefinition Width="1.1*" /></Grid.ColumnDefinitions>
                                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <TextBlock Text="Текущая смена" FontSize="26" FontWeight="Black" />
                                        <TextBlock Text="Администратор: Ivan K. · 10:00-22:00" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,20" />
                                        <UniformGrid Columns="2" Margin="0,0,0,16">
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0"><StackPanel><TextBlock Text="Касса" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="ShiftCashValue" Text="1 248 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="28" FontWeight="Black" /></StackPanel></Border>
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14"><StackPanel><TextBlock Text="Онлайн" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="ShiftOnlineValue" Text="694 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="28" FontWeight="Black" /></StackPanel></Border>
                                        </UniformGrid>
                                        <Button Content="Внести расход" Style="{StaticResource GhostButtonStyle}" Tag="shift-expense" Click="AdminAction_Click" Margin="0,0,0,10" />
                                        <Button Content="Печать отчета" Style="{StaticResource GhostButtonStyle}" Tag="shift-report" Click="AdminAction_Click" />
                                    </StackPanel>
                                </Border>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                    <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Задачи смены" FontSize="26" FontWeight="Black" Margin="0,0,0,14" />
                                            <CheckBox x:Name="ShiftTaskVipCheck" Content="Проверить VIP-зону после 18:00" IsChecked="True" Click="ShiftTask_Click" Margin="0,0,0,10" />
                                            <CheckBox x:Name="ShiftTaskBootcampCheck" Content="Подготовить Bootcamp к тренировке Team Alpha" Click="ShiftTask_Click" Margin="0,0,0,10" />
                                            <CheckBox x:Name="ShiftTaskPaymentCheck" Content="Проверить оплату ожидающих броней" IsChecked="True" Click="ShiftTask_Click" />
                                        </StackPanel>
                                    </Border>
                                    <Border Grid.Row="1" Style="{StaticResource PanelBorderStyle}">
                                        <StackPanel x:Name="ShiftIncidentList">
                                            <TextBlock Text="Журнал инцидентов" FontSize="26" FontWeight="Black" Margin="0,0,0,14" />
                                            <TextBlock Text="17:20 · STD-07 отправлен на обслуживание" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,10" />
                                            <TextBlock Text="18:05 · VIP-06 замена периферии" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,10" />
                                            <Button Content="Добавить запись" Style="{StaticResource PrimaryButtonStyle}" Tag="shift-incident" Click="AdminAction_Click" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </StackPanel>
</UserControl>
