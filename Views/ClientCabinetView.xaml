<UserControl x:Class="VictusLounge.Views.ClientCabinetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<StackPanel>
                            <DockPanel Margin="0,0,0,18">
                                <StackPanel>
                                    <TextBlock Text="CLIENT PROFILE" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Личный кабинет" FontSize="38" FontWeight="Black" Margin="0,7,0,8" />
                                    <TextBlock Text="Профиль игрока, лояльность, активные брони, сессии и быстрые действия." Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <Button Content="Забронировать ПК"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Tag="booking"
                                        Click="NavigationButton_Click"
                                        Visibility="Collapsed" />
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.75*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.RowSpan="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="74" Height="74" CornerRadius="22" Background="{DynamicResource GoldButtonBrush}" Margin="0,0,16,0">
                                                <Viewbox Width="34" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#111111" Data="M12,12 C14.761,12 17,9.761 17,7 C17,4.239 14.761,2 12,2 C9.239,2 7,4.239 7,7 C7,9.761 9.239,12 12,12 Z" />
                                                        <Path Fill="#111111" Data="M4,22 C4,17.582 7.582,14 12,14 C16.418,14 20,17.582 20,22 Z" />
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <Border CornerRadius="10" Background="#24D4AF37" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="9,4" HorizontalAlignment="Left" Margin="0,0,0,9">
                                                    <TextBlock Text="Gold" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" FontSize="12" />
                                                </Border>
                                                <TextBlock x:Name="CabinetUserNameText" Text="Client" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                                                <TextBlock x:Name="CabinetTierText" Text="Bronze · Silver · Gold · Elite" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Grid>

                                        <TextBlock Text="Прогресс до Elite" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                                        <Grid Height="12" Margin="0,0,0,10">
                                            <Border CornerRadius="6" Background="{DynamicResource LineSoftBrush}" />
                                            <Border Width="260" CornerRadius="6" Background="{DynamicResource GoldButtonBrush}" HorizontalAlignment="Left" />
                                        </Grid>
                                        <TextBlock x:Name="CabinetProgressText" Text="0% · нет бонусных очков" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,0,0,20" />

                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#15D4AF37" Padding="14" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="Активная бронь" FontWeight="Bold" />
                                                    <TextBlock x:Name="CabinetActiveBookingText" Text="Нет активной брони" Foreground="{DynamicResource MutedBrush}" Margin="0,5,0,0" />
                                                </StackPanel>
                                                <TextBlock x:Name="CabinetActiveBookingPriceText" Grid.Column="1" Text="0 BYN" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                <Button x:Name="CabinetCancelBookingButton" Grid.Column="2" Content="Отменить" Style="{StaticResource GhostButtonStyle}" Visibility="Collapsed" Click="CabinetCancelBooking_Click" Padding="16,8" />
                                            </Grid>
                                        </Border>

                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Следующая выгода" FontWeight="Bold" />
                                                <TextBlock x:Name="CabinetNextBenefitText" Text="Подсказка обновится после загрузки тарифов." Style="{StaticResource MutedTextStyle}" Margin="0,5,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1">
                                    <UniformGrid Columns="4" Margin="0,0,0,16">
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#19D4AF37" Padding="14" Margin="0,0,10,0">
                                            <StackPanel><TextBlock Text="Баланс" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="CabinetBalanceText" Text="0 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,7,0,0" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                            <StackPanel><TextBlock Text="Получено бонусов" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="CabinetBonusText" Text="0" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,7,0,0" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                            <StackPanel><TextBlock Text="Наиграно" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="CabinetPlayedText" Text="0 ч" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,7,0,0" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14">
                                            <StackPanel><TextBlock Text="Любимая зона" Foreground="{DynamicResource MutedBrush}" /><TextBlock x:Name="CabinetFavoriteZoneText" Text="-" Foreground="{DynamicResource GoldLightBrush}" FontSize="22" FontWeight="Black" Margin="0,7,0,0" TextWrapping="Wrap" /></StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                                        <StackPanel>
                                            <TextBlock Text="Быстрые действия" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />
                                            <UniformGrid Columns="4">
                                                <Button Content="Забронировать ПК" Style="{StaticResource GhostButtonStyle}" Tag="booking" Click="NavigationButton_Click" Margin="0,0,10,0" />
                                                <Button Content="Пополнить баланс" Style="{StaticResource GhostButtonStyle}" Tag="topup" Click="CabinetAction_Click" Margin="0,0,10,0" />
                                                <Button Content="Оплатить бронь" Style="{StaticResource GhostButtonStyle}" Tag="package" Click="CabinetAction_Click" Margin="0,0,10,0" />
                                                <Button Content="События" Style="{StaticResource GhostButtonStyle}" Tag="events" Click="CabinetAction_Click" />
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="0.85*" />
                                            <ColumnDefinition Width="1.15*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                            <StackPanel>
                                                <TextBlock Text="Активные брони" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />
                                                <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14">
                                                    <StackPanel>
                                                        <TextBlock x:Name="CabinetBookingCardPcText" Text="Нет брони" FontSize="18" FontWeight="Black" />
                                                        <TextBlock x:Name="CabinetBookingCardTimeText" Text="" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" />
                                                        <TextBlock x:Name="CabinetBookingCardPriceText" Text="" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" Margin="0,10,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Текущая сессия" FontSize="22" FontWeight="Bold" Margin="0,0,0,14" />
                                                <Grid x:Name="CabinetSessionsGrid">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="0.7*" />
                                                        <ColumnDefinition Width="0.8*" />
                                                        <ColumnDefinition Width="1.2*" />
                                                        <ColumnDefinition Width="0.7*" />
                                                        <ColumnDefinition Width="0.8*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="Дата" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                                    <TextBlock Grid.Column="1" Text="ПК" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                                    <TextBlock Grid.Column="2" Text="Зона" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                                    <TextBlock Grid.Column="3" Text="Время" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                                    <TextBlock Grid.Column="4" Text="Сумма" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Right" />

                                                    <TextBlock Grid.Row="1" Text="06.05" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="VIP-03" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Royal VIP" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="3" Text="2 ч" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="32 BYN" HorizontalAlignment="Right" Margin="0,12,0,0" />

                                                    <TextBlock Grid.Row="2" Text="04.05" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="STD-12" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Standard" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="3" Text="3 ч" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="2" Grid.Column="4" Text="24 BYN" HorizontalAlignment="Right" Margin="0,12,0,0" />

                                                    <TextBlock Grid.Row="3" Text="01.05" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="BA-02" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="2" Text="Bootcamp" Foreground="{DynamicResource MutedBrush}" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="3" Text="5 ч" Margin="0,12,0,0" />
                                                    <TextBlock Grid.Row="3" Grid.Column="4" Text="50 BYN" HorizontalAlignment="Right" Margin="0,12,0,0" />
                                                </Grid>
                                                <Button x:Name="CabinetEndSessionButton"
                                                        Content="Завершить сессию"
                                                        Style="{StaticResource GhostButtonStyle}"
                                                        Visibility="Collapsed"
                                                        Click="CabinetEndSession_Click"
                                                        Margin="0,16,0,0"
                                                        HorizontalAlignment="Right"
                                                        Padding="18,8" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
</UserControl>
