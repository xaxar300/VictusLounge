<UserControl x:Class="VictusLounge.Views.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<StackPanel>
                            <DockPanel Margin="0,0,0,18" LastChildFill="False">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock x:Name="EventsKickerText" Text="EVENTS" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock x:Name="EventsTitleText" Text="События клуба" FontSize="38" FontWeight="Black" Margin="0,7,0,8" />
                                    <TextBlock x:Name="EventsSubtitleText" Text="Турниры, LAN-вечера и клубные активности с местами, взносом и призовым фондом." Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                                <Border DockPanel.Dock="Right" CornerRadius="13" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="5" VerticalAlignment="Top">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="EventFilterAllButton" Content="Все" Style="{StaticResource PrimaryButtonStyle}" Tag="all" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" />
                                        <Button x:Name="EventFilterDotaButton" Content="Dota 2" Style="{StaticResource GhostButtonStyle}" Tag="dota" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                                        <Button x:Name="EventFilterCsButton" Content="CS2" Style="{StaticResource GhostButtonStyle}" Tag="cs2" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                                        <Button x:Name="EventFilterLanButton" Content="LAN" Style="{StaticResource GhostButtonStyle}" Tag="lan" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </DockPanel>

                            <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.35*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="NEXT EVENT" Style="{StaticResource KickerTextStyle}" />
                                        <TextBlock Text="Dota 2 Weekend Cup" FontSize="28" FontWeight="Black" Margin="0,8,0,8" />
                                        <TextBlock Text="Сегодня · 22:00 · Bootcamp Room · 12/16 участников" Style="{StaticResource MutedTextStyle}" />
                                    </StackPanel>
                                    <Border Grid.Column="1" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#14D4AF37" Padding="14" Margin="18,0,0,0">
                                        <StackPanel>
                                            <TextBlock x:Name="EventApplicationsTitleText" Text="Мои заявки" FontWeight="Black" />
                                            <TextBlock x:Name="EventApplicationsText" Text="Пока нет активных заявок" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Border>

                            <UniformGrid Columns="3">
                                <Border x:Name="DotaEventCard" Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0" Tag="dota">
                                    <StackPanel>
                                        <Border CornerRadius="10" Background="#2468D889" Padding="9,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <TextBlock Text="Dota 2" Foreground="{DynamicResource OkBrush}" FontWeight="Black" FontSize="12" />
                                        </Border>
                                        <TextBlock Text="Dota 2 Weekend Cup" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                                        <TextBlock Text="Суббота, 22:00 · 5x5 · взнос 150 BYN" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,16" />
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Приз: 600 BYN" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                            <TextBlock Grid.Column="1" Text="Мест: 4" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Button Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="Dota 2 Weekend Cup|Dota 2|22:00" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="CsEventCard" Style="{StaticResource PanelBorderStyle}" Margin="0,0,12,0" Tag="cs2">
                                    <StackPanel>
                                        <Border CornerRadius="10" Background="#24EDC86B" Padding="9,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <TextBlock Text="CS2" Foreground="{DynamicResource WaitBrush}" FontWeight="Black" FontSize="12" />
                                        </Border>
                                        <TextBlock Text="CS2 Night Tournament" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                                        <TextBlock Text="Пятница, 23:30 · 2x2 · взнос 80 BYN" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,16" />
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Приз: 320 BYN" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                            <TextBlock Grid.Column="1" Text="Мест: 6" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Button Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="CS2 Night Tournament|CS2|23:30" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                    </StackPanel>
                                </Border>

                                <Border x:Name="LanEventCard" Style="{StaticResource PanelBorderStyle}" Tag="lan">
                                    <StackPanel>
                                        <Border CornerRadius="10" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Padding="9,4" HorizontalAlignment="Left" Margin="0,0,0,12">
                                            <TextBlock Text="LAN" Foreground="{DynamicResource MutedBrush}" FontWeight="Black" FontSize="12" />
                                        </Border>
                                        <TextBlock Text="LAN Party" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                                        <TextBlock Text="Воскресенье, 19:00 · free format · без взноса" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,16" />
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                            <TextBlock Text="Призы клуба" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                            <TextBlock Grid.Column="1" Text="Мест: 12" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" HorizontalAlignment="Right" />
                                        </Grid>
                                        <Button Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="LAN Party|LAN|19:00" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>
                        </StackPanel>
</UserControl>
