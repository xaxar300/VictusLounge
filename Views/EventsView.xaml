<UserControl x:Class="VictusLounge.Views.EventsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <DockPanel Margin="0,0,0,18" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock x:Name="EventsKickerText" Text="EVENTS" Style="{StaticResource KickerTextStyle}" />
                <TextBlock x:Name="EventsTitleText" Text="События клуба" FontSize="38" FontWeight="Black" Margin="0,7,0,8" />
                <TextBlock x:Name="EventsSubtitleText" Text="Турниры, LAN-вечера и клубные активности с местами, взносом и призовым фондом." Style="{StaticResource MutedTextStyle}" />
            </StackPanel>
            <Border DockPanel.Dock="Right" CornerRadius="13" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="5" VerticalAlignment="Top">
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="EventFilterAllButton" Content="Все" Style="{StaticResource PrimaryButtonStyle}" Tag="all" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" />
                    <Button x:Name="EventFilterDotaButton" Content="Dota 2" Style="{StaticResource GhostButtonStyle}" Tag="dota" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                    <Button x:Name="EventFilterCsButton" Content="CS2" Style="{StaticResource GhostButtonStyle}" Tag="cs2" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                    <Button x:Name="EventFilterLanButton" Content="LAN" Style="{StaticResource GhostButtonStyle}" Tag="lan" Command="{Binding Events.FilterCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" MinHeight="34" Padding="14,0" Margin="6,0,0,0" />
                </StackPanel>
            </Border>
        </DockPanel>

        <Border CornerRadius="18" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="0" Margin="0,0,0,18" ClipToBounds="True">
            <Grid MinHeight="320">
                <Grid.Background>
                    <ImageBrush ImageSource="pack://application:,,,/Assets/Events.png" Stretch="UniformToFill" />
                </Grid.Background>
                <Rectangle Fill="#A8060606" />
                <Rectangle>
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#F1070707" Offset="0" />
                            <GradientStop Color="#B0070707" Offset="0.54" />
                            <GradientStop Color="#44070707" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Grid Margin="28">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.25*" />
                        <ColumnDefinition Width="0.75*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel VerticalAlignment="Center">
                        <Border CornerRadius="10" Background="#24D4AF37" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Padding="10,5" HorizontalAlignment="Left" Margin="0,0,0,16">
                            <TextBlock Text="NEXT EVENT · TODAY 22:00" Foreground="{DynamicResource GoldLightBrush}" FontSize="12" FontWeight="Black" />
                        </Border>
                        <TextBlock Text="Dota 2 Weekend Cup" FontSize="44" FontWeight="Black" TextWrapping="Wrap" />
                        <TextBlock Text="Bootcamp Room · 5x5 Captain Mode · 12/16 участников" Foreground="{DynamicResource MutedBrush}" FontSize="16" Margin="0,10,0,0" TextWrapping="Wrap" />
                        <UniformGrid Columns="3" Margin="0,24,0,26" MaxWidth="560" HorizontalAlignment="Left">
                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="#AA111111" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Формат" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                    <TextBlock Text="5x5" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="#AA111111" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="Взнос" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                    <TextBlock Text="150 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="#AA111111" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Приз" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                    <TextBlock Text="600 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="24" FontWeight="Black" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        <Button x:Name="DotaHeroJoinButton" Content="Записаться на Dota 2 Weekend Cup" Style="{StaticResource PrimaryButtonStyle}" Tag="Dota 2 Weekend Cup|Dota 2|22:00" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Width="320" HorizontalAlignment="Left" />
                    </StackPanel>

                    <Border Grid.Column="1" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#D50F0F0F" Padding="20" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock x:Name="EventApplicationsTitleText" Text="Мои заявки" FontWeight="Black" FontSize="22" />
                            <TextBlock x:Name="EventApplicationsText" Text="Пока нет активных заявок" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,20" TextWrapping="Wrap" />
                            <Button x:Name="CancelEventApplicationButton" Content="Отменить заявку" Style="{StaticResource GhostButtonStyle}" Tag="cancel-event" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" Visibility="Collapsed" Margin="0,0,0,16" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="22:00" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Dota 2 Weekend Cup" FontWeight="Bold" />
                                    <TextBlock Text="4 места свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="70" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <TextBlock Text="23:30" Foreground="{DynamicResource WaitBrush}" FontWeight="Black" />
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="CS2 Night Tournament" FontWeight="Bold" />
                                    <TextBlock Text="6 мест свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <UniformGrid Columns="3">
            <Border x:Name="DotaEventCard" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource PanelGradientBrush}" Padding="0" Margin="0,0,14,0" Tag="dota" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="128" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Background="#1834C759">
                        <Grid>
                            <TextBlock Text="DOTA 2" Foreground="{DynamicResource OkBrush}" FontSize="34" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border CornerRadius="10" Background="#DD101010" Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16">
                                <TextBlock Text="5x5 · BO1" Foreground="{DynamicResource OkBrush}" FontWeight="Black" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="18">
                        <TextBlock Text="Dota 2 Weekend Cup" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                        <TextBlock Text="Суббота, 22:00 · Bootcamp Room" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,16" />
                        <UniformGrid Columns="3" Margin="0,0,0,18">
                            <StackPanel><TextBlock Text="Взнос" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="150" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Приз" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="600" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Мест" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="4" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                        </UniformGrid>
                        <Button x:Name="DotaEventJoinButton" Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="Dota 2 Weekend Cup|Dota 2|22:00" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="CsEventCard" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource PanelGradientBrush}" Padding="0" Margin="0,0,14,0" Tag="cs2" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="128" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Background="#1AEDC86B">
                        <Grid>
                            <TextBlock Text="CS2" Foreground="{DynamicResource WaitBrush}" FontSize="38" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border CornerRadius="10" Background="#DD101010" Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16">
                                <TextBlock Text="2x2 · aim maps" Foreground="{DynamicResource WaitBrush}" FontWeight="Black" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="18">
                        <TextBlock Text="CS2 Night Tournament" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                        <TextBlock Text="Пятница, 23:30 · VIP Zone" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,16" />
                        <UniformGrid Columns="3" Margin="0,0,0,18">
                            <StackPanel><TextBlock Text="Взнос" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="80" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Приз" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="320" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Мест" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="6" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                        </UniformGrid>
                        <Button x:Name="CsEventJoinButton" Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="CS2 Night Tournament|CS2|23:30" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="LanEventCard" CornerRadius="16" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource PanelGradientBrush}" Padding="0" Tag="lan" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="128" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <Border Background="#18FFFFFF">
                        <Grid>
                            <TextBlock Text="LAN" Foreground="{DynamicResource MutedBrush}" FontSize="38" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <Border CornerRadius="10" Background="#DD101010" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Padding="9,4" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16">
                                <TextBlock Text="free format" Foreground="{DynamicResource MutedBrush}" FontWeight="Black" FontSize="12" />
                            </Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="18">
                        <TextBlock Text="LAN Party" FontSize="24" FontWeight="Black" TextWrapping="Wrap" />
                        <TextBlock Text="Воскресенье, 19:00 · весь клуб" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,16" />
                        <UniformGrid Columns="3" Margin="0,0,0,18">
                            <StackPanel><TextBlock Text="Взнос" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="0" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Приз" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="мерч" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                            <StackPanel><TextBlock Text="Мест" Foreground="{DynamicResource MutedBrush}" FontSize="11" /><TextBlock Text="12" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" /></StackPanel>
                        </UniformGrid>
                        <Button x:Name="LanEventJoinButton" Content="Записаться" Style="{StaticResource PrimaryButtonStyle}" Tag="LAN Party|LAN|19:00" Command="{Binding Events.JoinCommand}" CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}" />
                    </StackPanel>
                </Grid>
            </Border>
        </UniformGrid>
    </StackPanel>
</UserControl>
