<UserControl x:Class="VictusLounge.Views.ClubMapView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
<StackPanel>
                            <DockPanel Margin="0,0,0,18" LastChildFill="False">
                                <StackPanel>
                                    <TextBlock Text="CLUB MAP" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Интерактивная схема клуба" FontSize="38" FontWeight="Black" Margin="0,7,0,8" TextWrapping="Wrap" />
                                    <TextBlock Text="Зоны клуба, статусы ПК и ближайшие свободные интервалы видны без перехода в таблицы." Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </DockPanel>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="500" />
                                </Grid.ColumnDefinitions>

                                <Border Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="72" />
                                            <RowDefinition Height="180" />
                                            <RowDefinition Height="118" />
                                            <RowDefinition Height="114" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.4*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Row="0" Grid.Column="0" CornerRadius="10" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,10">
                                            <StackPanel><TextBlock Text="Entrance" FontWeight="Bold" /><TextBlock Text="ресепшен / турникет" Foreground="{DynamicResource MutedBrush}" FontSize="12" /></StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="1" CornerRadius="10" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,10">
                                            <StackPanel><TextBlock Text="Admin Desk" FontWeight="Bold" /><TextBlock Text="касса и старт сессий" Foreground="{DynamicResource MutedBrush}" FontSize="12" /></StackPanel>
                                        </Border>
                                        <Border Grid.Row="0" Grid.Column="2" CornerRadius="10" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,0,10">
                                            <StackPanel><TextBlock Text="Service" FontWeight="Bold" /><TextBlock Text="склад / техника" Foreground="{DynamicResource MutedBrush}" FontSize="12" /></StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#19000000" Padding="14" Margin="0,0,10,10">
                                            <StackPanel>
                                                <TextBlock Text="Standard Hall" FontWeight="Bold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="7">
                                                    <Button Content="STD-01" Tag="STD-01|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-02" Tag="STD-02|Standard|busy" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-03" Tag="STD-03|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-04" Tag="STD-04|Standard|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-05" Tag="STD-05|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-06" Tag="STD-06|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-07" Tag="STD-07|Standard|service" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="STD-08" Tag="STD-08|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-09" Tag="STD-09|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-10" Tag="STD-10|Standard|busy" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-11" Tag="STD-11|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-12" Tag="STD-12|Standard|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-13" Tag="STD-13|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="STD-14" Tag="STD-14|Standard|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="1" Grid.Column="2" Grid.RowSpan="2" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#1DD4AF37" Padding="14" Margin="0,0,0,10">
                                            <StackPanel>
                                                <TextBlock Text="VIP Zone" FontWeight="Bold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="2">
                                                    <Button Content="VIP-01" Tag="VIP-01|VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-02" Tag="VIP-02|VIP|busy" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-03" Tag="VIP-03|VIP|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-04" Tag="VIP-04|VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-05" Tag="VIP-05|VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-06" Tag="VIP-06|VIP|service" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-07" Tag="VIP-07|VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                    <Button Content="VIP-08" Tag="VIP-08|VIP|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,7" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#1468D889" Padding="14" Margin="0,0,10,10">
                                            <StackPanel>
                                                <TextBlock Text="Bootcamp Room" FontWeight="Bold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="5">
                                                    <Button Content="BA-01" Tag="BA-01|Bootcamp|busy" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="BA-02" Tag="BA-02|Bootcamp|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="BA-03" Tag="BA-03|Bootcamp|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="BA-04" Tag="BA-04|Bootcamp|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="BA-05" Tag="BA-05|Bootcamp|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#22FFFFFF" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Royal VIP" FontWeight="Bold" Margin="0,0,0,10" />
                                                <UniformGrid Columns="5">
                                                    <Button Content="RV-01" Tag="RV-01|Royal VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="RV-02" Tag="RV-02|Royal VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="RV-03" Tag="RV-03|Royal VIP|reserved" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="RV-04" Tag="RV-04|Royal VIP|service" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" Margin="0,0,7,0" />
                                                    <Button Content="RV-05" Tag="RV-05|Royal VIP|free" Click="PcButton_Click" Style="{StaticResource PcButtonStyle}" />
                                                </UniformGrid>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource PanelBorderStyle}" Width="500" Height="540" VerticalAlignment="Top" HorizontalAlignment="Right">
                                    <StackPanel>
                                        <TextBlock Text="PC DETAIL" Style="{StaticResource KickerTextStyle}" />
                                        <TextBlock x:Name="PcDetailTitle" Text="Выберите ПК" FontSize="26" FontWeight="Black" Margin="0,8,0,8" TextWrapping="Wrap" />
                                        <TextBlock x:Name="PcDetailSubtitle" Text="После выбора здесь появятся зона, статус, железо, тариф и ближайшие свободные интервалы." Style="{StaticResource MutedTextStyle}" MaxHeight="44" />
                                        <Border x:Name="PcPhotoFrame"
                                                Height="170"
                                                CornerRadius="12"
                                                BorderBrush="{DynamicResource LineBrush}"
                                                BorderThickness="1"
                                                Background="{DynamicResource SurfaceBrush}"
                                                Margin="0,18,0,16">
                                            <Grid>
                                                <Grid.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#242424" Offset="0" />
                                                        <GradientStop Color="#101010" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Grid.Background>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="Фото места" Foreground="{DynamicResource GoldLightBrush}" FontSize="18" FontWeight="Black" HorizontalAlignment="Center" />
                                                    <TextBlock x:Name="PcPhotoCaption" Text="Заглушка до загрузки реальных фото" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,8,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <Grid Margin="0,18,0,16">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.1*" /><ColumnDefinition Width="0.9*" /></Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <TextBlock Text="CPU" Foreground="{DynamicResource MutedBrush}" />
                                            <TextBlock x:Name="PcCpuText" Grid.Column="1" Text="—" FontWeight="Bold" HorizontalAlignment="Right" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1" Text="GPU" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0" />
                                            <TextBlock x:Name="PcGpuText" Grid.Row="1" Grid.Column="1" Text="—" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="2" Text="RAM" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0" />
                                            <TextBlock x:Name="PcRamText" Grid.Row="2" Grid.Column="1" Text="—" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="3" Text="Monitor" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0" />
                                            <TextBlock x:Name="PcMonitorText" Grid.Row="3" Grid.Column="1" Text="—" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,10,0,0" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                        <TextBlock x:Name="PcIntervalsText" Text="Свободные интервалы появятся после выбора места." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" MaxHeight="44" Margin="0,0,0,16" />
                                        <Button x:Name="BookSelectedPcButton" Content="Забронировать выбранный ПК" Style="{StaticResource PrimaryButtonStyle}" Click="BookSelectedPc_Click" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
</UserControl>
