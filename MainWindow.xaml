<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="VictusLounge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Elite Gaming Lounge Control Center"
        Width="1480"
        Height="860"
        MinWidth="1120"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Background="{DynamicResource WindowBackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Grid x:Name="RootGrid"
          Background="{DynamicResource WindowBackgroundBrush}"
          PreviewMouseDown="RootGrid_PreviewMouseDown">
        <Border x:Name="ShellRoot" Background="{DynamicResource ShellBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="50" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="SidebarColumn" Width="264" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Background="{DynamicResource TitlebarBrush}"
                        BorderBrush="{DynamicResource LineSoftBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,24,0">
                            <TextBlock Text="Elite Gaming Lounge Control Center"
                                       Foreground="{DynamicResource MutedBrush}"
                                       FontSize="13"
                                       VerticalAlignment="Center" />
                            <TextBlock Text=" / " Foreground="{DynamicResource DimBrush}" FontSize="13" Margin="8,0" />
                            <TextBlock x:Name="CurrentViewText"
                                       Text="Главная"
                                       Foreground="{DynamicResource GoldLightBrush}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="390"
                                Height="34"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                CornerRadius="11"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="12,0"
                                Margin="0,0,14,0">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="⌕" Foreground="{DynamicResource GoldLightBrush}" VerticalAlignment="Center" Margin="0,0,9,0" />
                                <TextBox x:Name="GlobalSearchBox"
                                         Text="Поиск: клиент, PC-04, бронь, турнир, платеж..."
                                         Foreground="{DynamicResource MutedBrush}"
                                         GotFocus="GlobalSearchBox_GotFocus"
                                         TextChanged="GlobalSearchBox_TextChanged" />
                            </DockPanel>
                        </Border>

                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,14,0">
                            <TextBlock x:Name="TopLanguageLabel" Text="Language" Foreground="{DynamicResource MutedBrush}" VerticalAlignment="Center" Margin="0,0,8,0" />
                            <Border CornerRadius="13" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="5">
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="TopRuButton" Content="RU" Style="{StaticResource PrimaryButtonStyle}" MinHeight="28" Padding="12,0" Tag="ru" Click="LanguageButton_Click" />
                                    <Button x:Name="TopEnButton" Content="EN" Style="{StaticResource GhostButtonStyle}" MinHeight="28" Padding="12,0" Tag="en" Click="LanguageButton_Click" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <Border Grid.Column="3"
                                CornerRadius="14"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1"
                                Background="{DynamicResource SurfaceBrush}"
                                Padding="10,5"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                            <TextBlock x:Name="WorkspaceText" Text="Client workspace" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                        </Border>

                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button x:Name="NotificationButton"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Width="42"
                                    MinHeight="34"
                                    Padding="0"
                                    Margin="0,0,8,0"
                                    Click="NotificationButton_Click">
                                <Grid>
                                    <TextBlock Text="●" Foreground="{DynamicResource GoldLightBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    <Border x:Name="NotificationBadge" CornerRadius="7" Background="{DynamicResource DangerBrush}" Padding="4,0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-3,-5,0" Visibility="Collapsed">
                                        <TextBlock x:Name="NotificationCountText" Text="0" FontSize="10" FontWeight="Bold" />
                                    </Border>
                                </Grid>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border x:Name="Sidebar"
                        Grid.Row="1"
                        Grid.Column="0"
                        BorderBrush="{DynamicResource LineSoftBrush}"
                        BorderThickness="0,0,1,0"
                        Background="{DynamicResource ShellBackgroundBrush}"
                        Padding="19">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="46" Height="46" CornerRadius="14" Background="{DynamicResource GoldButtonBrush}">
                                <TextBlock Text="E" Foreground="#111111" FontSize="22" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel x:Name="BrandTextPanel" Grid.Column="1" Margin="12,0,8,0" VerticalAlignment="Center">
                                <TextBlock x:Name="BrandTitle" Text="Elite Gaming" FontWeight="Bold" />
                                <TextBlock x:Name="BrandSubtitle" Text="Premium PC Club" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    x:Name="SidebarToggle"
                                    Content="‹"
                                    Style="{StaticResource GhostButtonStyle}"
                                    Width="34"
                                    MinHeight="34"
                                    Padding="0"
                                    Click="SidebarToggle_Click" />
                        </Grid>

                        <ScrollViewer Grid.Row="1" Margin="0,18,0,18" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <Button x:Name="DashboardNavButton" Style="{StaticResource SidebarButtonStyle}" Background="#2BD4AF37" Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Tag="dashboard" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="◆" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Главная" /></StackPanel>
                                </Button>
                                <Button x:Name="MapNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="map" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="▦" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Схема клуба" /></StackPanel>
                                </Button>
                                <Button x:Name="BookingNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="booking" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="▣" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Бронирование" /></StackPanel>
                                </Button>
                                <Button x:Name="CabinetNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="cabinet" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="◈" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Кабинет" /></StackPanel>
                                </Button>
                                <Button x:Name="BalanceNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="balance" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="₽" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Баланс" /></StackPanel>
                                </Button>
                                <Button x:Name="EventsNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="events" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="◎" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="События" /></StackPanel>
                                </Button>
                                <Button x:Name="AdminNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="admin" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="▤" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Админ" /></StackPanel>
                                </Button>
                                <Button x:Name="ShiftNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="shift" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="▥" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Смена" /></StackPanel>
                                </Button>
                                <Button x:Name="OwnerNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="owner" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="◇" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Owner" /></StackPanel>
                                </Button>
                                <Button x:Name="SettingsNavButton" Style="{StaticResource SidebarButtonStyle}" Margin="0,7,0,0" Tag="settings" Click="NavigationButton_Click">
                                    <StackPanel Orientation="Horizontal"><TextBlock Text="⚙" Foreground="{DynamicResource GoldLightBrush}" Width="30" /><TextBlock Text="Настройки" /></StackPanel>
                                </Button>
                            </StackPanel>
                        </ScrollViewer>

                        <Border x:Name="SidebarProfileCard" Grid.Row="2" CornerRadius="16" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#14D4AF37" Padding="13">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="46" Height="46" CornerRadius="14" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}">
                                    <TextBlock x:Name="ProfileInitialsText" Text="--" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel x:Name="ProfileText" Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="ProfileNameText" Text="Client" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock x:Name="ProfileRoleText" Text="Client" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid Grid.Row="3" Margin="0,14,0,0">
                            <TextBlock x:Name="LogoutText" Text="Выйти" Foreground="{DynamicResource MutedBrush}" FontSize="12" HorizontalAlignment="Left" Cursor="Hand" MouseLeftButtonUp="LogoutText_MouseLeftButtonUp" />
                            <TextBlock x:Name="SidebarVersionText" Text="v1.0 demo" Foreground="{DynamicResource MutedBrush}" FontSize="12" HorizontalAlignment="Right" />
                        </Grid>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Background="{DynamicResource WindowBackgroundBrush}">
                    <StackPanel Margin="18">
                        <Border x:Name="AnnouncementBar"
                                Height="40"
                                CornerRadius="13"
                                BorderBrush="{DynamicResource LineBrush}"
                                BorderThickness="1"
                                Background="#1CD4AF37"
                                ClipToBounds="True"
                                Margin="0,0,0,18">
                            <Canvas x:Name="AnnouncementCanvas" Margin="18,0">
                                <TextBlock x:Name="AnnouncementTextA"
                                           Text="Данные клуба загружаются из SQL Server · тарифы, брони и статусы ПК обновятся после подключения ·"
                                           Foreground="{DynamicResource GoldLightBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Canvas.Top="11" />
                                <TextBlock x:Name="AnnouncementTextB"
                                           Text="{Binding Text, ElementName=AnnouncementTextA}"
                                           Foreground="{DynamicResource GoldLightBrush}"
                                           FontSize="13"
                                           VerticalAlignment="Center"
                                           Canvas.Top="11" />
                            </Canvas>
                        </Border>

                        <StackPanel x:Name="DashboardView">
                        <Border Style="{StaticResource PanelBorderStyle}" Padding="24" Margin="0,0,0,16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.05*" />
                                    <ColumnDefinition Width="1.5*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0">
                                    <TextBlock Text="CLUB STATUS" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Рабочая панель клуба" FontSize="38" FontWeight="Black" Margin="0,7,0,8" TextWrapping="Wrap" />
                                    <TextBlock Text="Состояние зала, броней и смены на сегодня." Style="{StaticResource MutedTextStyle}" />
                                    <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
                                        <Button Content="Новая бронь" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,11,0" Tag="booking" Click="NavigationButton_Click" />
                                        <Button Content="Схема" Style="{StaticResource GhostButtonStyle}" Margin="0,0,11,0" Tag="map" Click="NavigationButton_Click" />
                                        <Button Content="События" Style="{StaticResource GhostButtonStyle}" Tag="events" Click="QuickAction_Click" />
                                    </StackPanel>
                                </StackPanel>

                                <UniformGrid Grid.Row="0" Grid.Column="1" Columns="4" Margin="20,0,0,0">
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#13D4AF37" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Свободно ПК" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock Text="42" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock Text="из 56" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Активные брони" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock Text="17" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock Text="5 ожидают оплату" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13" Margin="0,0,10,0">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Активные сессии" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock Text="21" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock Text="3 заканчиваются скоро" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="13">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="События сегодня" Foreground="{DynamicResource MutedBrush}" FontSize="12" />
                                            <TextBlock Text="3" Foreground="{DynamicResource GoldLightBrush}" FontSize="32" FontWeight="Black" Margin="0,7,0,5" />
                                            <TextBlock Text="Dota 2 · CS2 · LAN" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <UniformGrid Grid.Row="1" Grid.ColumnSpan="2" Columns="4" Margin="0,20,0,0">
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Standard" FontWeight="Bold" />
                                            <ProgressBar x:Name="StandardZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="VIP" FontWeight="Bold" />
                                            <ProgressBar x:Name="VipZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,10,0">
                                        <StackPanel>
                                            <TextBlock Text="Bootcamp" FontWeight="Bold" />
                                            <ProgressBar x:Name="BootcampZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                        </StackPanel>
                                    </Border>
                                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="Royal" FontWeight="Bold" />
                                            <ProgressBar x:Name="RoyalZoneLoadBar" Value="0" Height="8" Margin="0,10,0,0" Foreground="{DynamicResource GoldBrush}" Background="{DynamicResource SurfaceBrush}" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Border>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.ColumnSpan="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,16">
                                <StackPanel>
                                    <TextBlock Text="QUICK ACTIONS" Style="{StaticResource KickerTextStyle}" />
                                    <TextBlock Text="Быстрые действия" FontSize="22" FontWeight="Bold" Margin="0,6,0,16" />
                                    <UniformGrid Columns="4">
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="116" Background="{DynamicResource PanelGradientBrush}" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="booking" Click="QuickAction_Click">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Новая бронь" FontWeight="Bold" /><TextBlock Text="Дата, зона, ПК, summary" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap" /></StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="116" Background="{DynamicResource PanelGradientBrush}" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="tournament" Click="QuickAction_Click">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Записаться на турнир" FontWeight="Bold" TextWrapping="Wrap" /><TextBlock Text="Dota 2, CS2, LAN Party" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap" /></StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="116" Background="{DynamicResource PanelGradientBrush}" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Margin="0,0,10,0" Tag="package" Click="QuickAction_Click">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Купить пакет" FontWeight="Bold" /><TextBlock Text="Quick Game / Night Pack" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap" /></StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource SidebarButtonStyle}" Height="116" Background="{DynamicResource PanelGradientBrush}" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Tag="profile" Click="QuickAction_Click">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Открыть профиль" FontWeight="Bold" /><TextBlock Text="Бонусы, сессии, брони" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap" /></StackPanel>
                                        </Button>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,0,16">
                                <StackPanel x:Name="TodayClubList">
                                    <TextBlock Text="Сегодня в клубе" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                                    <TextBlock Text="Данные загружаются из бронирований и сессий." Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.ColumnSpan="2" Style="{StaticResource PanelBorderStyle}" Margin="0,0,16,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,16">
                                        <Button Content="Схема" DockPanel.Dock="Right" Style="{StaticResource GhostButtonStyle}" MinHeight="34" Padding="14,0" />
                                        <StackPanel>
                                            <TextBlock Text="ZONES" Style="{StaticResource KickerTextStyle}" />
                                            <TextBlock Text="Зоны клуба" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                    <UniformGrid Columns="4">
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#21D4AF37" Padding="14" Height="104" Margin="0,0,10,0" Cursor="Hand" Tag="Standard" MouseLeftButtonUp="ZoneCard_MouseLeftButtonUp">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Standard" /><TextBlock Text="28 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="23" FontWeight="Black" Margin="0,5,0,4" /><TextBlock Text="8 BYN/час · 18 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#2EF2D57A" Padding="14" Height="104" Margin="0,0,10,0" Cursor="Hand" Tag="VIP" MouseLeftButtonUp="ZoneCard_MouseLeftButtonUp">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="VIP" /><TextBlock Text="10 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="23" FontWeight="Black" Margin="0,5,0,4" /><TextBlock Text="14 BYN/час · 4 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#2268D889" Padding="14" Height="104" Margin="0,0,10,0" Cursor="Hand" Tag="Bootcamp" MouseLeftButtonUp="ZoneCard_MouseLeftButtonUp">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Bootcamp" /><TextBlock Text="2 комнаты" Foreground="{DynamicResource GoldLightBrush}" FontSize="23" FontWeight="Black" Margin="0,5,0,4" /><TextBlock Text="50 BYN/час · 1 свободна" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" /></StackPanel>
                                        </Border>
                                        <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#22FFFFFF" Padding="14" Height="104" Cursor="Hand" Tag="Royal VIP" MouseLeftButtonUp="ZoneCard_MouseLeftButtonUp">
                                            <StackPanel VerticalAlignment="Bottom"><TextBlock Text="Royal VIP" /><TextBlock Text="4 ПК" Foreground="{DynamicResource GoldLightBrush}" FontSize="23" FontWeight="Black" Margin="0,5,0,4" /><TextBlock Text="18 BYN/час · 3 свободно" Foreground="{DynamicResource MutedBrush}" FontSize="12" TextWrapping="Wrap" /></StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="2" Style="{StaticResource PanelBorderStyle}">
                                <StackPanel>
                                    <TextBlock Text="Последние уведомления" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,13"><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Ellipse Width="10" Height="10" Fill="{DynamicResource OkBrush}" VerticalAlignment="Top" Margin="0,5,0,0" /><StackPanel Grid.Column="1"><TextBlock Text="PC-07 свободен" FontWeight="Bold" /><TextBlock Text="Standard Hall" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" /></StackPanel></Grid>
                                    <Grid Margin="0,0,0,13"><Grid.ColumnDefinitions><ColumnDefinition Width="22" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Ellipse Width="10" Height="10" Fill="{DynamicResource WaitBrush}" VerticalAlignment="Top" Margin="0,5,0,0" /><StackPanel Grid.Column="1"><TextBlock Text="Бронь скоро начнется" FontWeight="Bold" TextWrapping="Wrap" /><TextBlock Text="VIP-03 · 18:00" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" /></StackPanel></Grid>
