                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                                <StackPanel><TextBlock Text="Client" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Брони, баланс, события" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                                <StackPanel><TextBlock Text="Admin" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Сессии, касса, статусы ПК" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14">
                                                <StackPanel><TextBlock Text="Owner" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Analytics, тарифы, сотрудники" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="28" Background="#33000000">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="АВТОРИЗАЦИЯ" Style="{StaticResource KickerTextStyle}" />
                                <TextBlock Text="Вход в приложение" FontSize="32" FontWeight="Black" Margin="0,8,0,10" />
                                <TextBlock Text="Введите логин и пароль пользователя из базы данных." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,18" />
                                <TextBlock Text="Логин или email" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                <Border Height="42" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12,0" Margin="0,0,0,12">
                                    <TextBox x:Name="LoginBox" Text="client1" Foreground="{DynamicResource TextBrush}" VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Text="Пароль" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                <Border Height="42" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12,0" Margin="0,0,0,14">
                                    <PasswordBox x:Name="LoginPasswordBox" Password="client123" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource GoldLightBrush}" VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock x:Name="AuthErrorText" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,12" />
                                <UniformGrid Columns="3" Margin="0,0,0,14" Visibility="Collapsed">
                                    <Button x:Name="LoginRoleClientButton" Content="Client" Style="{StaticResource PrimaryButtonStyle}" MinHeight="36" Padding="0" Margin="0,0,8,0" Tag="client" Click="AuthRole_Click" />
                                    <Button x:Name="LoginRoleAdminButton" Content="Admin" Style="{StaticResource GhostButtonStyle}" MinHeight="36" Padding="0" Margin="0,0,8,0" Tag="admin" Click="AuthRole_Click" />
                                    <Button x:Name="LoginRoleOwnerButton" Content="Owner" Style="{StaticResource GhostButtonStyle}" MinHeight="36" Padding="0" Tag="owner" Click="AuthRole_Click" />
                                </UniformGrid>
                                <Button Content="Войти" Style="{StaticResource PrimaryButtonStyle}" Click="AuthEnter_Click" Margin="0,0,0,10" />
                                <Button Content="Создать аккаунт" Style="{StaticResource GhostButtonStyle}" Click="ShowRegisterAuth_Click" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="RegisterAuthView" Grid.Row="1" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.85*" />
                            <ColumnDefinition Width="1.15*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Padding="28" Background="#33000000">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="НОВЫЙ ПРОФИЛЬ" Style="{StaticResource KickerTextStyle}" />
                                <TextBlock Text="Регистрация" FontSize="32" FontWeight="Black" Margin="0,8,0,10" />
                                <TextBlock Text="Новый аккаунт будет сохранен в таблицу Users." Style="{StaticResource MutedTextStyle}" Margin="0,0,0,18" />
                                <TextBlock Text="Имя" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                <Border Height="42" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12,0" Margin="0,0,0,12">
                                    <TextBox x:Name="RegisterFullNameBox" Text="" Foreground="{DynamicResource TextBrush}" VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Text="Логин" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                <Border Height="42" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12,0" Margin="0,0,0,12">
                                    <TextBox x:Name="RegisterLoginBox" Text="" Foreground="{DynamicResource TextBrush}" VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock Text="Пароль" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                                <Border Height="42" CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12,0" Margin="0,0,0,14">
                                    <PasswordBox x:Name="RegisterPasswordBox" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextBrush}" CaretBrush="{DynamicResource GoldLightBrush}" VerticalContentAlignment="Center" />
                                </Border>
                                <TextBlock x:Name="RegisterErrorText" Foreground="{DynamicResource DangerBrush}" FontWeight="Bold" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,0,0,12" />
                                <UniformGrid Columns="3" Margin="0,0,0,14" Visibility="Collapsed">
                                    <Button x:Name="RegisterRoleClientButton" Content="Client" Style="{StaticResource PrimaryButtonStyle}" MinHeight="36" Padding="0" Margin="0,0,8,0" Tag="client" Click="AuthRole_Click" />
                                    <Button x:Name="RegisterRoleAdminButton" Content="Admin" Style="{StaticResource GhostButtonStyle}" MinHeight="36" Padding="0" Margin="0,0,8,0" Tag="admin" Click="AuthRole_Click" />
                                    <Button x:Name="RegisterRoleOwnerButton" Content="Owner" Style="{StaticResource GhostButtonStyle}" MinHeight="36" Padding="0" Tag="owner" Click="AuthRole_Click" />
                                </UniformGrid>
                                <Button Content="Создать и войти" Style="{StaticResource PrimaryButtonStyle}" Click="AuthEnter_Click" Margin="0,0,0,10" />
                                <Button Content="Уже есть аккаунт" Style="{StaticResource GhostButtonStyle}" Click="ShowLoginAuth_Click" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Padding="28" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1,0,0,0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                                    <Border Width="54" Height="54" CornerRadius="16" Background="{DynamicResource GoldButtonBrush}" Margin="0,0,14,0">
                                        <TextBlock Text="E" Foreground="#111111" FontSize="24" FontWeight="Black" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Elite Gaming Lounge" FontWeight="Black" />
                                        <TextBlock Text="Premium PC Club" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </StackPanel>
                                <Border Style="{StaticResource PanelBorderStyle}" Padding="24">
                                    <StackPanel>
                                        <TextBlock Text="PLAYER IDENTITY" Style="{StaticResource KickerTextStyle}" />
                                        <TextBlock Text="Профиль хранит любимые ПК, бонусы и историю сессий" FontSize="34" FontWeight="Black" TextWrapping="Wrap" Margin="0,8,0,12" />
                                        <TextBlock Text="После регистрации клиенту доступны бронь, пакеты времени, события и история посещений." Style="{StaticResource MutedTextStyle}" />
                                        <UniformGrid Columns="3" Margin="0,22,0,0">
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                                <StackPanel><TextBlock Text="Лояльность" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Bronze / Silver / Gold / Elite" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14" Margin="0,0,10,0">
                                                <StackPanel><TextBlock Text="Команды" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Бронь нескольких ПК" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                            <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="14">
                                                <StackPanel><TextBlock Text="События" Foreground="{DynamicResource MutedBrush}" /><TextBlock Text="Турниры и LAN-вечера" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" TextWrapping="Wrap" Margin="0,8,0,0" /></StackPanel>
                                            </Border>
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="TopupOverlay"
              Background="#99000000"
              Visibility="Collapsed">
            <Border Width="560"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <DockPanel Margin="0,0,0,16" LastChildFill="False">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="BALANCE TOP-UP" Style="{StaticResource KickerTextStyle}" />
                            <TextBlock Text="Пополнение баланса" FontSize="28" FontWeight="Black" Margin="0,6,0,0" />
                        </StackPanel>
                        <Button Content="×"
                                DockPanel.Dock="Right"
                                Style="{StaticResource GhostButtonStyle}"
                                Width="38"
                                MinHeight="34"
                                Padding="0"
                                Click="CloseTopupOverlay_Click" />
                    </DockPanel>

                    <TextBlock Text="Сумма пополнения" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,7" />
                    <Border Height="42"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="12,0"
                            Margin="0,0,0,10">
                        <TextBox x:Name="TopupAmountBox"
                                 Text="50"
                                 FontWeight="Bold"
                                 TextChanged="TopupAmountBox_TextChanged"
                                 VerticalContentAlignment="Center" />
                    </Border>

                    <UniformGrid Columns="4" Margin="0,0,0,14">
                        <Button Content="25 BYN" Style="{StaticResource GhostButtonStyle}" Tag="25" Click="TopupAmountPreset_Click" MinHeight="34" Padding="0" Margin="0,0,8,0" />
                        <Button Content="50 BYN" Style="{StaticResource PrimaryButtonStyle}" Tag="50" Click="TopupAmountPreset_Click" MinHeight="34" Padding="0" Margin="0,0,8,0" />
                        <Button Content="100 BYN" Style="{StaticResource GhostButtonStyle}" Tag="100" Click="TopupAmountPreset_Click" MinHeight="34" Padding="0" Margin="0,0,8,0" />
                        <Button Content="200 BYN" Style="{StaticResource GhostButtonStyle}" Tag="200" Click="TopupAmountPreset_Click" MinHeight="34" Padding="0" />
                    </UniformGrid>

                    <TextBlock Text="Способ пополнения" Foreground="{DynamicResource MutedBrush}" Margin="0,0,0,8" />
                    <UniformGrid Columns="3" Margin="0,0,0,14">
                        <Button x:Name="TopupCardMethodButton"
                                Content="Карта"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Tag="card"
                                Click="TopupMethod_Click"
                                Margin="0,0,8,0" />
                        <Button x:Name="TopupEripMethodButton"
                                Content="ЕРИП"
                                Style="{StaticResource GhostButtonStyle}"
                                Tag="erip"
                                Click="TopupMethod_Click"
                                Margin="0,0,8,0" />
                        <Button x:Name="TopupCashMethodButton"
                                Content="Наличные"
                                Style="{StaticResource GhostButtonStyle}"
                                Tag="cash"
                                Click="TopupMethod_Click" />
                    </UniformGrid>

                    <Border x:Name="TopupCardFields"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource LineSoftBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource SurfaceBrush}"
                            Padding="14"
                            Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="Данные карты" FontWeight="Bold" Margin="0,0,0,10" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.4*" />
                                    <ColumnDefinition Width="0.7*" />
                                    <ColumnDefinition Width="0.7*" />
                                </Grid.ColumnDefinitions>
                                <Border Height="40" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" Padding="10,0" Margin="0,0,8,0">
                                    <TextBox x:Name="TopupCardNumberBox" Text="4242 4242 4242 4242" VerticalContentAlignment="Center" />
                                </Border>
                                <Border Grid.Column="1" Height="40" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" Padding="10,0" Margin="0,0,8,0">
                                    <TextBox Text="12/28" VerticalContentAlignment="Center" />
                                </Border>
                                <Border Grid.Column="2" Height="40" CornerRadius="11" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="{DynamicResource PanelBrush}" Padding="10,0">
                                    <TextBox Text="123" VerticalContentAlignment="Center" />
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="TopupMethodHintText"
                               Text="Оплата картой сейчас доступна в демо-режиме. ЕРИП и наличные создают заявку без зачисления."
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,0,0,10" />
                    <Border CornerRadius="12"
                            BorderBrush="{DynamicResource LineBrush}"
                            BorderThickness="1"
                            Background="#14D4AF37"
                            Padding="12"
                            Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Итого к зачислению" FontWeight="Bold" />
                                <TextBlock x:Name="TopupBonusText" Text="+5 бонусов по Gold" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <TextBlock x:Name="TopupSummaryText" Grid.Column="1" Text="50 BYN" Foreground="{DynamicResource GoldLightBrush}" FontSize="22" FontWeight="Black" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <TextBlock x:Name="TopupErrorText"
                               Foreground="{DynamicResource DangerBrush}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,10"
                               Visibility="Collapsed" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена"
                                Style="{StaticResource GhostButtonStyle}"
                                Click="CloseTopupOverlay_Click"
                                Margin="0,0,10,0" />
                        <Button x:Name="ConfirmTopupButton"
                                Content="Пополнить"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="ConfirmTopup_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
        <Border x:Name="NotificationCenter"
                Width="390"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,58,58,0"
                CornerRadius="16"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelGradientBrush}"
                Padding="16"
                Visibility="Collapsed">
            <StackPanel>
                <DockPanel LastChildFill="False" Margin="0,0,0,14">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="NOTIFICATION CENTER" Style="{StaticResource KickerTextStyle}" />
                        <TextBlock Text="Уведомления" FontSize="24" FontWeight="Black" Margin="0,5,0,0" />
                    </StackPanel>
                    <Button x:Name="MarkNotificationsButton"
                            Content="Прочитать"
                            DockPanel.Dock="Right"
                            Style="{StaticResource GhostButtonStyle}"
                            MinHeight="34"
                            Padding="14,0"
                            Click="MarkNotifications_Click" />
                </DockPanel>

                <StackPanel x:Name="NotificationList">
                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineBrush}" BorderThickness="1" Background="#14D4AF37" Padding="12" Margin="0,0,0,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="NotificationUnreadBookingDot" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource GoldLightBrush}" Margin="0,7,10,0" VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Бронь" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                <TextBlock Text="VIP-03 начнется через 25 минут" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Сегодня, 18:00" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,0,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="NotificationUnreadSessionDot" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource DangerBrush}" Margin="0,7,10,0" VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Сессия" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                <TextBlock Text="STD-12 заканчивается через 10 минут" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Админу: предложить продление" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,0,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="NotificationUnreadTournamentDot" Width="8" Height="8" CornerRadius="4" Background="{DynamicResource OkBrush}" Margin="0,7,10,0" VerticalAlignment="Top" />
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Турнир" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                                <TextBlock Text="Открыта запись на CS2 Night Tournament" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap" />
                                <TextBlock Text="Осталось 6 мест" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12" Margin="0,0,0,9">
                        <StackPanel>
                            <TextBlock Text="Баланс" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                            <TextBlock Text="Баланс ниже 20 BYN" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="Рекомендован Evening Pack" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="12" BorderBrush="{DynamicResource LineSoftBrush}" BorderThickness="1" Background="{DynamicResource SurfaceBrush}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="Service" Foreground="{DynamicResource GoldLightBrush}" FontWeight="Bold" />
                            <TextBlock Text="PC-18 переведен в обслуживание" FontWeight="Bold" Margin="0,5,0,0" TextWrapping="Wrap" />
                            <TextBlock Text="15:42, админ Кирилл" Foreground="{DynamicResource MutedBrush}" FontSize="12" Margin="0,5,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock x:Name="NotificationEmptyText"
                           Text="Новых уведомлений нет."
                           Foreground="{DynamicResource MutedBrush}"
                           TextAlignment="Center"
                           Padding="16"
                           Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <Border x:Name="StatusToast"
                Width="360"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,24,24"
                CornerRadius="14"
                BorderBrush="{DynamicResource LineBrush}"
                BorderThickness="1"
                Background="{DynamicResource PanelGradientBrush}"
                Padding="16"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock x:Name="StatusTitleText"
                           Text="Готово"
                           Foreground="{DynamicResource GoldLightBrush}"
                           FontWeight="Black"
                           FontSize="15"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="StatusBodyText"
                           Text="Действие выполнено."
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,6,0,0"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid x:Name="BookingConfirmOverlay"
              Background="{DynamicResource WindowBackgroundBrush}"
              Visibility="Collapsed">
            <Border Width="460"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Style="{StaticResource PanelBorderStyle}">
                <StackPanel>
                    <TextBlock Text="БРОНЬ СОЗДАНА" Style="{StaticResource KickerTextStyle}" />
                    <TextBlock Text="Подтверждение" FontSize="28" FontWeight="Black" Margin="0,8,0,12" />
                    <TextBlock x:Name="BookingConfirmText"
                               Foreground="{DynamicResource MutedBrush}"
                               TextWrapping="Wrap"
                               LineHeight="23" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="Оплатить позже" Style="{StaticResource GhostButtonStyle}" Click="CloseBookingConfirm_Click" Margin="0,0,10,0" />
                        <Button Content="Готово" Style="{StaticResource PrimaryButtonStyle}" Click="CloseBookingConfirm_Click" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>


