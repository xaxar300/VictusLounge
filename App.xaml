<Application x:Class="VictusLounge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             StartupUri="Views/MainWindow/MainWindow.xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <Color x:Key="BgColor">#070707</Color>
        <Color x:Key="ShellColor">#181818</Color>
        <Color x:Key="PanelColor">#1F1F1F</Color>
        <Color x:Key="SurfaceColor">#151515</Color>
        <Color x:Key="TextColor">#F6F0E3</Color>
        <Color x:Key="MutedColor">#A9A092</Color>
        <Color x:Key="DimColor">#70685E</Color>
        <Color x:Key="GoldColor">#D4AF37</Color>
        <Color x:Key="GoldLightColor">#F2D57A</Color>
        <Color x:Key="GoldDarkColor">#A88928</Color>
        <Color x:Key="LineColor">#4DD4AF37</Color>
        <Color x:Key="LineSoftColor">#17FFFFFF</Color>
        <Color x:Key="OkColor">#68D889</Color>
        <Color x:Key="DangerColor">#E66B6B</Color>
        <Color x:Key="WaitColor">#EDC86B</Color>

        <SolidColorBrush x:Key="ShellBrush" Color="{StaticResource ShellColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource PanelColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="DimBrush" Color="{StaticResource DimColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="GoldBrush" Color="{StaticResource GoldColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="GoldLightBrush" Color="{StaticResource GoldLightColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="LineBrush" Color="{StaticResource LineColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="LineSoftBrush" Color="{StaticResource LineSoftColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="OkBrush" Color="{StaticResource OkColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="WaitBrush" Color="{StaticResource WaitColor}" po:Freeze="False" />
        <SolidColorBrush x:Key="PcFreeBackgroundBrush" Color="#162F6F48" po:Freeze="False" />
        <SolidColorBrush x:Key="PcBusyBackgroundBrush" Color="#2AE66B6B" po:Freeze="False" />
        <SolidColorBrush x:Key="PcReservedBackgroundBrush" Color="#2AEDC86B" po:Freeze="False" />
        <SolidColorBrush x:Key="PcServiceBackgroundBrush" Color="#1AFFFFFF" po:Freeze="False" />
        <SolidColorBrush x:Key="StatusErrorBackgroundBrush" Color="#22E66B6B" po:Freeze="False" />
        <SolidColorBrush x:Key="StatusWarningBackgroundBrush" Color="#22EDC86B" po:Freeze="False" />
        <SolidColorBrush x:Key="StatusSuccessBackgroundBrush" Color="#2268D889" po:Freeze="False" />

        <Thickness x:Key="SpaceNone">0</Thickness>
        <Thickness x:Key="SpaceInlineXs">0,0,6,0</Thickness>
        <Thickness x:Key="SpaceInlineS">0,0,8,0</Thickness>
        <Thickness x:Key="SpaceInlineM">0,0,12,0</Thickness>
        <Thickness x:Key="SpaceStackXs">0,4,0,0</Thickness>
        <Thickness x:Key="SpaceStackS">0,8,0,0</Thickness>
        <Thickness x:Key="SpaceStackM">0,12,0,0</Thickness>
        <Thickness x:Key="SpaceStackL">0,16,0,0</Thickness>
        <Thickness x:Key="SpaceBelowXs">0,0,0,6</Thickness>
        <Thickness x:Key="SpaceBelowS">0,0,0,8</Thickness>
        <Thickness x:Key="SpaceBelowM">0,0,0,12</Thickness>
        <Thickness x:Key="SpaceBelowL">0,0,0,16</Thickness>
        <Thickness x:Key="SpaceSection">0,0,0,18</Thickness>
        <Thickness x:Key="SpacePanelRight">0,0,16,0</Thickness>
        <Thickness x:Key="SpaceWrapItem">0,0,8,8</Thickness>
        <Thickness x:Key="SpaceFormField">0,0,0,12</Thickness>
        <Thickness x:Key="SpaceInsetS">12</Thickness>
        <Thickness x:Key="SpaceHeading">0,8,0,16</Thickness>
        <Thickness x:Key="SpaceTitle">0,8,0,8</Thickness>
        <Thickness x:Key="SpaceLabelStack">0,12,0,8</Thickness>
        <Thickness x:Key="SpacePanelPadding">20</Thickness>
        <Thickness x:Key="SpaceControlPadding">18,0</Thickness>
        <Thickness x:Key="SpaceCompactControlPadding">12,0</Thickness>

        <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1" po:Freeze="False">
            <GradientStop Color="#050505" Offset="0" />
            <GradientStop Color="#111111" Offset="0.54" />
            <GradientStop Color="#070707" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="ShellBackgroundBrush" StartPoint="0,0" EndPoint="0,1" po:Freeze="False">
            <GradientStop Color="#FA1D1D1D" Offset="0" />
            <GradientStop Color="#FC080808" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TitlebarBrush" StartPoint="0,0" EndPoint="1,0" po:Freeze="False">
            <GradientStop Color="#1B1B1B" Offset="0" />
            <GradientStop Color="#101010" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="GoldButtonBrush" StartPoint="0,0" EndPoint="1,1" po:Freeze="False">
            <GradientStop Color="{StaticResource GoldLightColor}" Offset="0" />
            <GradientStop Color="{StaticResource GoldDarkColor}" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0,0" EndPoint="0,1" po:Freeze="False">
            <GradientStop Color="#EB1F1F1F" Offset="0" />
            <GradientStop Color="#EF0F0F0F" Offset="1" />
        </LinearGradientBrush>

        <DropShadowEffect x:Key="ShellShadow" BlurRadius="42" ShadowDepth="18" Opacity="0.45" Color="#000000" />

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource GoldLightBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                CornerRadius="4"
                                Background="#55A9A092"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource GoldBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{DynamicResource GoldLightBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Background" Value="#12111111" />
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Border x:Name="TrackChrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                BorderBrush="{DynamicResource LineSoftBrush}"
                                BorderThickness="1">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True"
                                   Focusable="False">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}" />
                                </Track.Thumb>
                            </Track>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto" />
                                <Setter Property="MinWidth" Value="0" />
                                <Setter Property="Height" Value="10" />
                                <Setter Property="MinHeight" Value="10" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TrackChrome" Property="Background" Value="#1CFFFFFF" />
                                <Setter TargetName="TrackChrome" Property="BorderBrush" Value="{DynamicResource LineBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource PanelGradientBrush}" />
            <Setter Property="Padding" Value="{StaticResource SpacePanelPadding}" />
        </Style>

        <Style x:Key="KickerTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource GoldLightBrush}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="LineHeight" Value="22" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="{StaticResource SpaceControlPadding}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="Background" Value="{DynamicResource GoldButtonBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.78" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="Padding" Value="{StaticResource SpaceControlPadding}" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Foreground" Value="{DynamicResource GoldLightBrush}" />
            <Setter Property="Background" Value="#09FFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#15FFFFFF" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="13,0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SidebarChrome" Background="{TemplateBinding Background}" CornerRadius="12">
                            <Grid>
                                <Border x:Name="ActiveIndicator"
                                        Width="3"
                                        HorizontalAlignment="Left"
                                        Margin="0,8,0,8"
                                        CornerRadius="2"
                                        Background="{DynamicResource GoldLightBrush}"
                                        Visibility="Collapsed" />
                                <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SidebarChrome" Property="Background" Value="#14D4AF37" />
                            </Trigger>
                            <Trigger Property="BorderThickness" Value="1">
                                <Setter TargetName="ActiveIndicator" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PcButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="MinHeight" Value="46" />
            <Setter Property="Padding" Value="3,0" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Black" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       LineHeight="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#15FFFFFF" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{DynamicResource GoldLightBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnavailablePcButtonStyle" TargetType="Button" BasedOn="{StaticResource PcButtonStyle}">
            <Setter Property="Foreground" Value="{DynamicResource MutedBrush}" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="{DynamicResource LineSoftBrush}" />
            <Setter Property="Opacity" Value="0.62" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <TextBlock Text="{TemplateBinding Content}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       LineHeight="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TimeButtonStyle" TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>

        <Style x:Key="SelectedTimeButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="Black" />
        </Style>
    </Application.Resources>
</Application>

